{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "BLOB_READ_WRITE_TOKEN", "XAI_API_KEY"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "check-types": {},
    "push": {
      "cache": false
    }
  }
}
